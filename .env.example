# ============================================================================
# Local Context RAG - Configuration File Template
# ============================================================================
# Copy this file to .env and configure with your local settings
# All relative paths are resolved from the project root directory

# ============================================================================
# LM Studio Configuration
# ============================================================================

# LM Studio API endpoint (local server must be enabled in LM Studio)
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# Embedding model name (must be loaded in LM Studio)
# Recommended: nomic-embed-text-v1.5
EMBEDDING_MODEL=nomic-embed-text-v1.5

# ============================================================================
# Document Storage
# ============================================================================

# Directory containing your Markdown documents
# Can be absolute or relative to project root
DOCUMENTS_DIR=documents

# ChromaDB persistent storage path
CHROMA_DB_PATH=chroma_db

# ChromaDB collection name
COLLECTION_NAME=local_context

# Index state tracking file (for incremental updates)
INDEX_STATE_PATH=chroma_db/index_state.json

# ============================================================================
# Chunking Strategy
# ============================================================================

# Chunking strategy: "markdown" or "paragraph"
# - markdown: Structure-aware chunking with section metadata (Recommended)
# - paragraph: Simple paragraph-based splitting
CHUNKING_STRATEGY=markdown

# Target chunk size in characters (chunks aim for this size)
# Default: 1400 (balanced for context windows)
CHUNK_TARGET_SIZE=1400

# Minimum chunk size in characters (avoid too-small chunks)
# Default: 350
CHUNK_MIN_SIZE=350

# ============================================================================
# Markdown-Aware Chunking Options (only applies when CHUNKING_STRATEGY=markdown)
# ============================================================================

# Include parent headers in chunk content for better context
# true: Each chunk includes its hierarchical header path
# false: Only include the chunk's own content
# Example: When true, a subsection includes "# Main > ## Section > ### Subsection"
CHUNK_INCLUDE_PARENT_HEADERS=true

# Extract [[wikilinks]] from content as metadata
# true: Wikilinks are indexed and searchable
# false: Wikilinks are treated as regular text
# Example: [[EntityName]], [[AnotherEntity]] become linked_entities metadata
CHUNK_EXTRACT_WIKILINKS=true

# ============================================================================
# Search & Retrieval
# ============================================================================

# Default number of search results to return
# Range: 1-20
SEARCH_DEFAULT_RESULTS=5

# Characters per snippet in search results
# Snippets show context around matched terms
SEARCH_SNIPPET_CHARS=450

# Maximum total characters across all search result snippets
# Prevents overwhelming the context window
SEARCH_MAX_CONTEXT_CHARS=2500

# ============================================================================
# Chunk Window Defaults (for get_document_chunk)
# ============================================================================

# Number of chunks to include before the target chunk
READ_DEFAULT_WINDOW_BEFORE=0

# Number of chunks to include after the target chunk
# Default: 1 (includes next chunk for continuity)
READ_DEFAULT_WINDOW_AFTER=1

# ============================================================================
# Logging
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
# INFO: Standard operation logs (recommended)
# DEBUG: Detailed debugging information
LOG_LEVEL=INFO